{
  "name": "piwigo/modern-formats",
  "description": "Piwigo plugin: auto-convert uploaded photos to WebP, with bulk conversion.",
  "license": "WTFPL",
  "type": "piwigo-plugin",
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10",
    "friendsofphp/php-cs-fixer": "^3.95",
    "phpstan/phpstan": "^2.2",
    "phpstan/phpstan-strict-rules": "^2.0"
  },
  "autoload-dev": {
    "classmap": ["include/"]
  },
  "scripts": {
    "test": "phpunit",
    "stan": "phpstan analyse",
    "cs": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix",
    "check": ["@cs", "@stan", "@test"]
  }
}
